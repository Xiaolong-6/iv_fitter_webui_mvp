{
  "name": "iv-fitter-webui-mvp-root",
  "version": "1.7.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p frontend/tsconfig.json && vite build",
    "test": "npm run test:frontend",
    "test:frontend": "npm --prefix frontend run test --",
    "preview": "vite preview",
    "release:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release_build.ps1",
    "portable:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build_portable_windows.ps1"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
